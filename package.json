{
  "name": "multiversal-agentic-swarm",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "sync": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' ts-node scripts/sync-metrics.ts"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/three": "^0.184.1",
    "astro": "^6.3.3",
    "capacitor-biometric-auth": "^0.1.1",
    "devalue": "^5.8.1",
    "three": "^0.184.0",
    "vite": "^8.0.13"
  }
}
