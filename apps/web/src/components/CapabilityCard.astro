---
interface Props {
	name: string;
	level: number;
	xp: string;
	icon: string;
}

const { name, level, xp, icon } = Astro.props;
---

<div class="bg-gray-900/50 border border-gray-800 p-6 rounded-2xl hover:border-blue-500/50 hover:bg-gray-900 transition-all group backdrop-blur-sm">
    <div class="flex justify-between items-center mb-6">
        <div class="p-3 bg-gray-800 rounded-lg group-hover:bg-blue-900/30 transition-colors">
            <span class="text-2xl">{icon}</span>
        </div>
        <div class="text-right">
            <span class="block text-[10px] text-blue-400 font-bold tracking-tighter uppercase">Power Level</span>
            <span class="text-2xl font-black text-white">{level}</span>
        </div>
    </div>
    <h3 class="text-lg font-bold text-gray-100 mb-3">{name}</h3>
    <div class="relative w-full bg-gray-800 h-1.5 rounded-full overflow-hidden mb-2">
        <div 
            class="absolute top-0 left-0 h-full bg-gradient-to-r from-blue-600 to-purple-500 rounded-full group-hover:from-blue-400 group-hover:to-purple-300 transition-all duration-1000" 
            style={`width: ${level}%`}
        ></div>
    </div>
    <div class="flex justify-between items-center text-[10px] font-bold">
        <span class="text-gray-500 uppercase tracking-widest">Progress</span>
        <span class="text-blue-500">{xp} <span class="text-gray-700">/ 13M</span></span>
    </div>
</div>
