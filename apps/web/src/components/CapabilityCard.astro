---
interface Props {
	name: string;
	level: number;
	xp: string;
	icon: string;
    color?: 'cyan' | 'magenta' | 'green';
}

const { name, level, xp, icon, color = 'cyan' } = Astro.props;

const colorMap = {
    cyan: 'border-cyan-500/30 text-cyan-400 shadow-cyan-900/10 bg-cyan-950/20 hover:border-cyan-400 hover:shadow-cyan-500/20',
    magenta: 'border-magenta-500/30 text-magenta-400 shadow-magenta-900/10 bg-magenta-950/20 hover:border-magenta-400 hover:shadow-magenta-500/20',
    green: 'border-green-500/30 text-green-400 shadow-green-900/10 bg-green-950/20 hover:border-green-400 hover:shadow-green-500/20',
};

const barMap = {
    cyan: 'from-cyan-600 to-blue-500 group-hover:from-cyan-400 group-hover:to-blue-400 shadow-[0_0_10px_rgba(0,255,255,0.3)]',
    magenta: 'from-magenta-600 to-purple-500 group-hover:from-magenta-400 group-hover:to-purple-400 shadow-[0_0_10px_rgba(255,0,255,0.3)]',
    green: 'from-green-600 to-emerald-500 group-hover:from-green-400 group-hover:to-emerald-400 shadow-[0_0_10px_rgba(57,255,20,0.3)]',
};

const currentCardClass = colorMap[color];
const currentBarClass = barMap[color];
---

<div class={`border p-6 rounded-2xl transition-all duration-300 group backdrop-blur-md relative overflow-hidden ${currentCardClass}`}>
    <!-- GLITCH DECOR -->
    <div class="absolute top-0 left-0 w-1 h-full bg-current opacity-20 group-hover:opacity-100 transition-opacity"></div>
    
    <div class="flex justify-between items-center mb-6">
        <div class="p-3 bg-black/40 rounded-lg group-hover:bg-current/10 transition-colors border border-white/5">
            <span class="text-2xl filter drop-shadow-[0_0_8px_rgba(255,255,255,0.3)]">{icon}</span>
        </div>
        <div class="text-right">
            <span class="block text-[8px] font-bold tracking-[0.2em] uppercase opacity-60">Neural Rank</span>
            <span class="text-3xl font-black italic tracking-tighter drop-shadow-sm">{level}</span>
        </div>
    </div>
    
    <h3 class="text-xs font-black uppercase tracking-widest mb-3 opacity-90 group-hover:opacity-100">{name}</h3>
    
    <div class="relative w-full bg-black/40 h-1 rounded-full overflow-hidden mb-2 border border-white/5">
        <div 
            class={`absolute top-0 left-0 h-full bg-gradient-to-r transition-all duration-1000 ${currentBarClass}`} 
            style={`width: ${level}%`}
        ></div>
    </div>
    
    <div class="flex justify-between items-center text-[8px] font-mono font-bold uppercase tracking-widest">
        <span class="opacity-40">Sync Rate</span>
        <span class="opacity-80">{xp} <span class="opacity-30">/ 13M XP</span></span>
    </div>
</div>
