---
const response = await fetch('http://localhost:8080/health-status.json').catch(() => ({}));
const health = await response.json ? response.json() : { cpu: 0, mem: 0 };
---
<div id="tree-of-life-container" class="w-full h-[600px] bg-black rounded-xl border border-magenta-500/30"></div>

<script>
  import * as THREE from 'three';

  const container = document.getElementById('tree-of-life-container');
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(75, container.clientWidth / container.clientHeight, 0.1, 1000);
  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
  renderer.setSize(container.clientWidth, container.clientHeight);
  container.appendChild(renderer.domElement);

  // Mapeo Sephiroth -> Habilidades del Avatar
  const sephiroth = [
    { name: "Kether", pos: [0, 5, 0], color: 0xffffff, cap: "Optimization" },
    { name: "Chokmah", pos: [2, 3, 0], color: 0xcccccc, cap: "Alchemy" },
    { name: "Binah", pos: [-2, 3, 0], color: 0x999999, cap: "Automation" },
    { name: "Chesed", pos: [2, 1, 0], color: 0x0000ff, cap: "Merchanting" },
    { name: "Geburah", pos: [-2, 1, 0], color: 0xff0000, cap: "Combat" },
    { name: "Tiphareth", pos: [0, 0, 0], color: 0xffff00, cap: "Smithing" },
    { name: "Netzach", pos: [2, -2, 0], color: 0x00ff00, cap: "Farming" },
    { name: "Hod", pos: [-2, -2, 0], color: 0xffa500, cap: "Woodcutting" },
    { name: "Yesod", pos: [0, -3, 0], color: 0x800080, cap: "Optimization" },
    { name: "Malkuth", pos: [0, -5, 0], color: 0x8b4513, cap: "Farming" },
  ];

  const spheres = sephiroth.map(s => {
    const geometry = new THREE.SphereGeometry(0.5, 32, 32);
    const material = new THREE.MeshBasicMaterial({ color: s.color });
    const sphere = new THREE.Mesh(geometry, material);
    sphere.position.set(...s.pos);
    scene.add(sphere);
    return sphere;
  });

  camera.position.z = 12;

  function animate(time) {
    requestAnimationFrame(animate);
    
    // Pulsación dinámica basada en nivel (Singularity Lvl 99)
    spheres.forEach((sphere, i) => {
        const scale = 1 + Math.sin(time * 0.005) * 0.2;
        sphere.scale.set(scale, scale, scale);
    });

    renderer.render(scene, camera);
  }
  animate(0);
</script>
