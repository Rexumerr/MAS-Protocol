<div class="px-4 py-2 bg-magenta-900/10 border-t border-magenta-500/20 flex items-center justify-between">
    <div class="flex items-center">
        <span class="text-magenta-500 mr-2">$</span>
        <input type="text" class="bg-transparent border-none outline-none text-cyan-400 w-full text-[10px] placeholder:text-cyan-900" placeholder="Execute vanguard command (e.g. 'forge --all')..." />
    </div>
    <div id="thermal-alert" class="hidden flex items-center gap-1 px-2 py-0.5 bg-red-900/40 border border-red-500/50 rounded-full animate-bounce">
        <span class="text-[8px] font-mono text-red-400 whitespace-nowrap">❄️ COOLING ACTIVE</span>
    </div>
    <button id="auth-btn" class="px-2 py-1 bg-cyan-500/20 border border-cyan-500/50 rounded text-[10px] text-cyan-400 hover:bg-cyan-500/40">
        🔐 UNLOCK VANGUARD
    </button>
</div>
<div id="terminal-logs" class="p-4 h-48 overflow-y-auto text-[10px] font-mono text-cyan-500"></div>

<script is:inline>
    window.addEventListener('DOMContentLoaded', async () => {
        const authBtn = document.getElementById('auth-btn');
        if (authBtn) {
            authBtn.addEventListener('click', async () => {
                try {
                    const { BiometricAuth } = await import('capacitor-biometric-auth');
                    const result = await BiometricAuth.checkBiometry();
                    if (result.isAvailable) {
                        const auth = await BiometricAuth.authenticate({ title: 'Vanguard Access', reason: 'Authenticate to unlock Neural Crypt' });
                        if (auth.authenticated) alert("Vanguard Access Granted.");
                    }
                } catch (e) { console.error("Biometric failure:", e); }
            });
        }

        const logs = ["> Oracle: Ingesting...", "> Brain: Calibrating...", "> [VANGUARD] Evolving..."];
        const container = document.getElementById('terminal-logs');
        const thermalAlert = document.getElementById('thermal-alert');
        let i = 0;

        setInterval(async () => {
            if (!container) return;
            const p = document.createElement('p');
            p.textContent = logs[i % logs.length];
            container.appendChild(p);
            container.scrollTop = container.scrollHeight;
            i++;

            try {
                const res = await fetch('/health-status.json');
                const status = await res.json();
                thermalAlert.classList.toggle('hidden', !status.cooling_active);
            } catch (e) {}
        }, 2500);
    });
</script>
