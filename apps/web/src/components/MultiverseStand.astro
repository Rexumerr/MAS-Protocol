<div id="canvas-container" class="w-full h-[400px] lg:h-[700px] relative cursor-grab active:cursor-grabbing rounded-3xl overflow-hidden border border-orange-500/20 bg-[#050505]">
    <div class="absolute top-6 left-6 z-10 pointer-events-none">
        <span class="text-[10px] text-orange-400 font-bold uppercase tracking-[0.5em] drop-shadow-[0_0_8px_rgba(251,146,60,0.8)]">Mythic Phoenix Grade S</span>
    </div>
    <div class="absolute bottom-6 right-6 z-10 pointer-events-none text-right">
        <span class="text-[8px] text-orange-500 font-mono block">AI_ORCHESTRATOR: ACTIVE</span>
        <span class="text-[8px] text-cyan-500/50 font-mono block">THUNDER_INTENSITY: HIGH</span>
    </div>
    <div id="three-canvas"></div>
</div>

<script>
    import * as THREE from 'three';

    let container, scene, camera, renderer, core, fireParticles, thunderSparks = [], grid;

    function createPhoenix() {
        const group = new THREE.Group();
        
        // Body: Translucent Fire Crystal
        const bodyGeo = new THREE.IcosahedronGeometry(1.2, 2);
        const bodyMat = new THREE.MeshPhysicalMaterial({
            color: 0xff4500,
            emissive: 0xff0000,
            emissiveIntensity: 2.0,
            transparent: true,
            opacity: 0.7,
            transmission: 0.9,
            thickness: 1.0,
        });
        const body = new THREE.Mesh(bodyGeo, bodyMat);
        group.add(body);

        // Wings (Particle Systems)
        const wingParticlesGeo = new THREE.BufferGeometry();
        const count = 4000;
        const positions = new Float32Array(count * 3);
        const colors = new Float32Array(count * 3);

        for(let i=0; i<count; i++) {
            positions[i*3] = (Math.random() - 0.5) * 6;
            positions[i*3+1] = (Math.random() - 0.5) * 3;
            positions[i*3+2] = (Math.random() - 0.5) * 2;
            
            colors[i*3] = 1.0; // R
            colors[i*3+1] = Math.random() * 0.4; // G
            colors[i*3+2] = 0.0; // B
        }

        wingParticlesGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        wingParticlesGeo.setAttribute('color', new THREE.BufferAttribute(colors, 3));

        const wingMat = new THREE.PointsMaterial({
            size: 0.04,
            vertexColors: true,
            transparent: true,
            opacity: 0.6,
            blending: THREE.AdditiveBlending
        });

        fireParticles = new THREE.Points(wingParticlesGeo, wingMat);
        group.add(fireParticles);

        return group;
    }

    function init() {
        container = document.getElementById('three-canvas');
        const width = document.getElementById('canvas-container').clientWidth;
        const height = document.getElementById('canvas-container').clientHeight;

        scene = new THREE.Scene();
        scene.fog = new THREE.FogExp2(0x050505, 0.1);

        camera = new THREE.PerspectiveCamera(75, width / height, 0.1, 1000);
        camera.position.set(0, 2, 8);
        camera.lookAt(0, 0, 0);

        renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(width, height);
        renderer.setPixelRatio(window.devicePixelRatio);
        container.appendChild(renderer.domElement);

        // Grid Floor
        grid = new THREE.GridHelper(20, 20, 0xff4500, 0x221100);
        grid.position.y = -3;
        scene.add(grid);

        // Core Phoenix
        core = createPhoenix();
        scene.add(core);

        // Thunder Sparks
        for(let i=0; i<8; i++) {
            const points = [new THREE.Vector3(0,0,0), new THREE.Vector3((Math.random()-0.5)*5, (Math.random()-0.5)*5, (Math.random()-0.5)*5)];
            const sparkGeo = new THREE.BufferGeometry().setFromPoints(points);
            const sparkMat = new THREE.LineBasicMaterial({ color: 0x00ffff, transparent: true, opacity: 0 });
            const spark = new THREE.Line(sparkGeo, sparkMat);
            scene.add(spark);
            thunderSparks.push(spark);
        }

        const ambientLight = new THREE.AmbientLight(0xffffff, 0.2);
        scene.add(ambientLight);

        animate();
    }

    function animate() {
        requestAnimationFrame(animate);
        const time = Date.now() * 0.001;

        core.rotation.y += 0.005;
        fireParticles.scale.y = 1 + Math.sin(time * 3) * 0.15;
        
        // Particle Ascension
        const pos = fireParticles.geometry.attributes.position.array;
        for(let i=0; i<pos.length; i+=3) {
            pos[i+1] += 0.02;
            if (pos[i+1] > 3) pos[i+1] = -2;
        }
        fireParticles.geometry.attributes.position.needsUpdate = true;

        // Thunder Flicker
        thunderSparks.forEach(s => {
            if (Math.random() > 0.96) {
                s.material.opacity = 1.0;
                s.geometry.setFromPoints([
                    new THREE.Vector3((Math.random()-0.5)*2, (Math.random()-0.5)*2, (Math.random()-0.5)*2),
                    new THREE.Vector3((Math.random()-0.5)*6, (Math.random()-0.5)*6, (Math.random()-0.5)*6)
                ]);
            } else {
                s.material.opacity *= 0.85;
            }
        });

        renderer.render(scene, camera);
    }

    init();

    window.addEventListener('resize', () => {
        const c = document.getElementById('canvas-container');
        if (!c) return;
        renderer.setSize(c.clientWidth, c.clientHeight);
        camera.aspect = c.clientWidth / c.clientHeight;
        camera.updateProjectionMatrix();
    });
</script>

<style>
    #three-canvas { width: 100%; height: 100%; filter: drop-shadow(0 0 30px rgba(255, 69, 0, 0.2)); }
</style>
