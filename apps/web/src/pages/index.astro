---
import Layout from '../layouts/Layout.astro';
import multiverseState from '../data/multiverse-state.json';
import CapabilityCard from '../components/CapabilityCard.astro';
import NeuralTerminal from '../components/NeuralTerminal.astro';
import MultiverseStand from '../components/MultiverseStand.astro';

const capabilities = [
  { name: 'Data Mining', level: multiverseState.DataMining || 85, xp: '12.5M', icon: '🔍' },
  { name: 'Automation', level: multiverseState.Automation || 99, xp: '13.1M', icon: '⚡' },
  { name: 'Infrastructure', level: multiverseState.Infrastructure || 72, xp: '8.2M', icon: '🏗️' },
  { name: 'Lead Gen', level: multiverseState.LeadGen || 64, xp: '5.9M', icon: '🎯' },
  { name: 'Optimization', level: multiverseState.Optimization || 45, xp: '3.1M', icon: '📈' },
  { name: 'Security', level: multiverseState.Security || 90, xp: '12.1M', icon: '🛡️' },
];
---

<Layout title="Multiversal Agentic Swarm | Command Center">
	<main class="min-h-screen bg-[#050505] text-white p-4 md:p-8 font-mono selection:bg-blue-500/30">
		<!-- Glow Effects -->
		<div class="fixed top-0 left-0 w-full h-full pointer-events-none">
			<div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-blue-900/20 blur-[120px] rounded-full"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-purple-900/10 blur-[120px] rounded-full"></div>
		</div>

		<header class="relative mb-12 flex flex-col md:flex-row justify-between items-start md:items-center border-b border-white/5 pb-8">
			<div>
				<div class="flex items-center space-x-2 mb-2">
					<span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
					<span class="text-[10px] text-green-500 font-bold tracking-[0.3em] uppercase">System Operational</span>
				</div>
				<h1 class="text-5xl font-black tracking-tighter italic">
					MULTIVERSAL <span class="text-blue-600 italic">SWARM</span>
				</h1>
			</div>
			<div class="mt-4 md:mt-0 text-right">
				<p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">Protocol: Ultra-Brain v1.0</p>
				<p class="text-2xl font-bold text-white/90">0.00042s <span class="text-gray-600 text-sm">LATENCY</span></p>
			</div>
		</header>

		<!-- 3D HERO SECTION -->
		<div class="relative grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">
			<div class="lg:col-span-2">
				<MultiverseStand />
			</div>
			<div class="grid grid-cols-1 gap-6">
				{capabilities.slice(0, 3).map(cap => (
					<CapabilityCard {...cap} />
				))}
			</div>
		</div>

		<div class="relative grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
			{capabilities.slice(3).map(cap => (
				<CapabilityCard {...cap} />
			))}
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 relative">
			<div class="lg:col-span-2 space-y-8">
				<section class="bg-white/[0.02] border border-white/5 p-8 rounded-3xl backdrop-blur-xl">
					<h2 class="text-2xl font-bold mb-6 flex items-center italic">
						<span class="text-blue-500 mr-3">//</span> ACTIVE DEPLOYMENTS
					</h2>
					<div class="space-y-6">
						<div class="group cursor-pointer">
							<div class="flex justify-between mb-2">
								<span class="text-sm font-bold text-gray-300">Quest: Regional Market Dominance</span>
								<span class="text-xs text-blue-500 font-bold">84%</span>
							</div>
							<div class="w-full bg-white/5 h-1 rounded-full overflow-hidden">
								<div class="bg-blue-600 w-[84%] h-full group-hover:bg-blue-400 transition-all"></div>
							</div>
						</div>
						<div class="group cursor-pointer opacity-50 grayscale hover:opacity-100 hover:grayscale-0 transition-all">
							<div class="flex justify-between mb-2">
								<span class="text-sm font-bold text-gray-300">Quest: High-Ticket Lead Factory</span>
								<span class="text-xs text-purple-500 font-bold">LOCKED</span>
							</div>
							<div class="w-full bg-white/5 h-1 rounded-full"></div>
						</div>
					</div>
				</section>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					<div class="bg-blue-600 p-8 rounded-3xl group cursor-pointer hover:bg-blue-500 transition-colors">
						<h3 class="text-xs font-bold uppercase tracking-widest mb-4 text-blue-200">Total Revenue Managed</h3>
						<p class="text-4xl font-black italic">$2.4M+</p>
						<span class="text-[10px] font-bold text-blue-200 mt-2 block">↑ 12% FROM LAST CYCLE</span>
					</div>
					<div class="bg-white/[0.02] border border-white/5 p-8 rounded-3xl">
						<h3 class="text-xs font-bold uppercase tracking-widest mb-4 text-gray-500">Agent Efficiency</h3>
						<p class="text-4xl font-black italic">99.9<span class="text-sm text-gray-600">%</span></p>
						<span class="text-[10px] font-bold text-green-500 mt-2 block">OPTIMAL PERFORMANCE</span>
					</div>
				</div>
			</div>

			<div class="space-y-6">
				<NeuralTerminal />
				<div class="bg-gradient-to-br from-gray-900 to-black border border-white/5 p-6 rounded-3xl">
					<h3 class="text-sm font-bold mb-4 uppercase tracking-tighter text-gray-400">Architect Message</h3>
					<p class="text-xs leading-relaxed text-gray-500 italic">
						"The multiverse is not just a structure, it's an organism. Each agent is a cell, each universe is a lung. We don't just automate; we breathe scale."
					</p>
				</div>
			</div>
		</div>

		<footer class="mt-20 border-t border-white/5 pt-8 flex justify-between items-center text-[10px] text-gray-600 font-bold uppercase tracking-[0.4em]">
			<span>© 2026 Multiversal Swarm</span>
			<span>Designed for High-Ticket Scaling</span>
		</footer>
	</main>
</Layout>
